# ── Base de datos (PostgreSQL) ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=as_terrasense
DB_USER=postgres
DB_PASSWORD=TU_PASSWORD_AQUI

# ── Flask / Seguridad ───────────────────────────────────────
# Genera valores fuertes: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-este-secret-key-en-produccion
JWT_SECRET_KEY=cambia-este-jwt-secret-key-en-produccion
JWT_ACCESS_TOKEN_EXPIRES=86400
FLASK_DEBUG=False

# ── API Keys externas ───────────────────────────────────────
# OpenWeather: https://openweathermap.org/api
# Groq (IA):   https://console.groq.com/keys
# Plant.id:    https://web.plant.id/
OPENWEATHER_API_KEY=TU_OPENWEATHER_API_KEY_AQUI
GROQ_API_KEY=TU_GROQ_API_KEY_AQUI
PLANT_ID_API_KEY=TU_PLANT_ID_API_KEY_AQUI

# ── URLs ────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ── Email (SMTP) ────────────────────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu_email@gmail.com
MAIL_PASSWORD=tu_app_password_aqui
ADMIN_EMAIL=tu_email@gmail.com

# ── Mantenimiento ───────────────────────────────────────────
# Días de retención al ejecutar scripts/limpiar_datos_antiguos.py
LIMPIEZA_DIAS=90
